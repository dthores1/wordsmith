# VCS
.git
.gitignore

# Editor / OS
.DS_Store
.vscode
.idea

# Python
.venv
venv
__pycache__
*.pyc
*.pyo

# Node — frontend deps and build output (image rebuilds these in the frontend stage)
app/node_modules
app/dist

# Local-only env files. Vite's convention: anything *.local is dev-only and
# must never reach a production build. The committed .env (no suffix) is
# what the production build picks up.
.env.local
.env.*.local
app/.env.local
app/.env.*.local

# Local SQLite created during local smoke testing
*.db

# Docs / images not needed at runtime
README.md
img
