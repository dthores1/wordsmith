# PostHog product analytics. Copy this file to `.env.local` and paste your
# project API key from https://us.posthog.com/project/<id>/settings/general
# (Project ID section, "Project API Key"). VITE_* vars are inlined into the
# JS bundle at build time, so they're visible to anyone with the app — that's
# expected for client-side analytics keys.
VITE_POSTHOG_KEY=phc_pytGbzwiLYykFAYs4nAKsrPU2a5JfC8vWR6aW4j4ZCyY
# Optional. Defaults to https://us.i.posthog.com. Set to https://eu.i.posthog.com
# if your PostHog project is in the EU region.
VITE_POSTHOG_HOST=
